# =====================================================================
# AutoQuote — Variáveis de ambiente (exemplo)
# Copie este arquivo para .env (raiz), backend/.env e frontend/.env.local
# conforme a necessidade de cada serviço. NUNCA versione o .env real.
# =====================================================================

# ---------------------------------------------------------------------
# SUPABASE — compartilhado
# ---------------------------------------------------------------------
# URL do projeto Supabase (Project Settings > API > Project URL)
SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co

# Chave anon (pública) — usada pelo frontend e para validar JWTs
# Project Settings > API > Project API keys > anon public
SUPABASE_ANON_KEY=eyJhbGciOi...sua_anon_key

# Service Role Key (SECRETA) — usada APENAS pelo backend (FastAPI/Railway)
# para inserir em eventos_coletados, atualizar robot_jobs e fazer upload
# para Storage com privilégios elevados. NUNCA expor no frontend.
# Project Settings > API > Project API keys > service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...sua_service_role_key

# JWT Secret do projeto — usado pelo backend para validar o token
# enviado pelo frontend (extrair user_id do JWT).
# Project Settings > API > JWT Settings > JWT Secret
SUPABASE_JWT_SECRET=seu-jwt-secret-do-supabase

# ---------------------------------------------------------------------
# BACKEND — FastAPI (Railway)
# ---------------------------------------------------------------------
# Porta em que o FastAPI sobe (Railway injeta automaticamente em produção)
PORT=8000

# Ambiente: development | production
ENV=development

# CORS — origem do frontend autorizada a chamar a API
# Em produção: https://autoquote.vercel.app (ou domínio próprio)
FRONTEND_ORIGIN=http://localhost:3000

# Nome do bucket de Storage onde as planilhas .xlsx serão gravadas
SUPABASE_STORAGE_BUCKET=planilhas

# (Opcional) Caminho do chromedriver / chrome dentro do container Docker
# Em geral o Dockerfile já configura — deixe vazio se não for sobrescrever.
CHROME_BIN=
CHROMEDRIVER_PATH=

# ---------------------------------------------------------------------
# FRONTEND — Next.js (Vercel)
# Variáveis com prefixo NEXT_PUBLIC_ são embarcadas no bundle do cliente.
# NUNCA coloque a SERVICE_ROLE_KEY aqui.
# ---------------------------------------------------------------------
# URL pública do Supabase (igual à SUPABASE_URL acima)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co

# Chave anon (igual à SUPABASE_ANON_KEY acima)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...sua_anon_key

# URL pública do backend FastAPI no Railway
# Em dev: http://localhost:8000
# Em prod: https://autoquote-backend.up.railway.app
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# URL do backend usada pelo Route Handler /api/run-robot (server-side
# do Next). Pode ser igual à NEXT_PUBLIC_BACKEND_URL, mas separada
# permite usar uma rede privada/interna em produção.
BACKEND_URL=http://localhost:8000
